# OpenAI API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# ==================== 其他兼容 OpenAI API 的服务 ====================

# SiliconFlow API (推荐 - 国内访问快，价格便宜)
# 文档: https://docs.siliconflow.cn/cn/api-reference/chat-completions/chat-completions
# OPENAI_API_KEY=your-siliconflow-api-key
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct

# DeepSeek API (性价比高)
# OPENAI_API_KEY=your-deepseek-api-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Azure OpenAI
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/
# OPENAI_MODEL=gpt-4

# 本地 Ollama (需要配合 litellm)
# OPENAI_API_KEY=sk-dummy
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama2

# ==================== 视觉分析配置 (v1.2.0 新功能) ====================
# 启用视觉模型分析图片，让海报更丰富
# ENABLE_VISION_ANALYSIS=true
# VISION_MODEL=gpt-4o-mini
# 
# 推荐视觉模型：
# - gpt-4o-mini (OpenAI - 推荐，性价比高)
# - Qwen/Qwen2-VL-7B-Instruct (SiliconFlow - 国内快，便宜)
# - gpt-4o (OpenAI - 质量最好，但贵)
# - Pro/Qwen/Qwen2-VL-72B-Instruct (SiliconFlow - 质量好)

# ==================== SiliconFlow 推荐模型 ====================
# 
# 高质量模型（适合论文转海报）:
# - deepseek-ai/DeepSeek-V3        (推荐 - 质量好，价格适中)
# - Qwen/Qwen2.5-72B-Instruct      (推荐 - 中文效果好)
# - Pro/deepseek-ai/DeepSeek-R1    (最强推理能力)
# - Qwen/QwQ-32B                   (推理模型)
# 
# 经济型模型（快速测试）:
# - Qwen/Qwen2.5-7B-Instruct       (轻量级，速度快)
# - THUDM/glm-4-9b-chat            (中文友好)
# 
# 更多模型请查看: https://cloud.siliconflow.cn/models

